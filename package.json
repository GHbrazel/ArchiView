{
  "name": "meta-lens",
  "displayName": "MetaLens",
  "description": "Listing Building Blocks",
  "publisher": "GHbrazel",
  "version": "0.0.1",
  "repository": "https://github.com/GHbrazel/ArchiView",
  "engines": {
    "vscode": "^1.107.0"
  },
  "keywords": [
    "annotation",
    "csharp",
    "metadata",
    "attributes",
    "code analysis",
    "static analysis",
    "reflection",
    "developer tools",
    "code navigation",
    "productivity"
  ],
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "MetaLens.ReportIssue",
        "title": "Report Issue",
        "category": "MetaLens"
      },
      {
        "command": "MetaLens.refresh",
        "title": "Refresh Attributes",
        "category": "MetaLens",
        "icon": "$(refresh)"
      },
      {
        "command": "MetaLens.toggleNamespaceHierarchy",
        "title": "Toggle Namespace Hierarchy",
        "category": "MetaLens",
        "icon": "$(settings)"
      },
      {
        "command": "MetaLens.showFilter",
        "title": "Filter Attributes",
        "category": "MetaLens",
        "icon": "$(filter)"
      }
    ],
    "menus": {
      "issue/reporter": [
        {
          "command": "MetaLens.ReportIssue"
        }
      ],
      "view/title": [
        {
          "command": "MetaLens.toggleNamespaceHierarchy",
          "when": "view == meta-lens-sidebar",
          "group": "navigation"
        },
        {
          "command": "MetaLens.refresh",
          "when": "view == meta-lens-sidebar",
          "group": "navigation"
        },
        {
          "command": "MetaLens.showFilter",
          "when": "view == meta-lens-sidebar",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "meta-lens",
          "title": "MetaLens",
          "icon": "$(telescope)"
        }
      ]
    },
    "views": {
      "meta-lens": [
        {
          "id": "meta-lens-sidebar",
          "icon": "$(telescope)",
          "name": "MetaLens"
        }
      ]
    },
    "configuration": {
      "title": "MetaLens",
      "properties": {
        "MetaLens.showNamespaceHierarchy": {
          "type": "boolean",
          "default": true,
          "description": "Show attributes organized by namespace hierarchy (true) or flat file list (false)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.4",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  }
}
