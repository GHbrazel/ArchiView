{
  "name": "archi-view",
  "displayName": "archi-view",
  "description": "Listing Building Blocks",
  "publisher": "GHbrazel",
  "version": "0.0.1",
  "icon": "media/houseWithPillarMagnified.png",
  "repository": "https://github.com/GHbrazel/ArchiView",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Visualization", 
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ArchiView",
        "title": "Building Blocks",
        "category": "Archi"
      },
      {
        "command": "ArchiView.ReportIssue",
        "title": "Report Issue",
        "category": "Archi"
      }
    ],
    "menus": {
      "issue/reporter": [
        {"command": "ArchiView.ReportIssue"}
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "archi-view",
          "title": "Archi View",
          "icon": "media/magnifiedHouseIcon.svg"
        }
      ]
    },
    "views": {
      "archi-view": [
        {
          "id": "archi-view-sidebar",
          "icon": "media/magnifiedHouseIcon.svg",
          "name": "Archi View"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
